# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Environment Variables Template
#
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env with your own values
#   3. Never commit .env to version control (it's in .gitignore)
#
# All variables below have defaults in docker-compose.yml,
# so this file is optional for local development.
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=inventory_db
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_pass   # Change this in production!

# ─── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=super-secret-change-in-production   # Use a long random string
FLASK_DEBUG=false                              # Set to "true" for hot-reload

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=8080   # Port exposed on your host machine
